<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Crow.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Crow"
    Shell.FlyoutBehavior="Disabled"
    Title="Crow">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
        <ShellContent Title="Contas a Ver" ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent Title="Adicionar Conta" ContentTemplate="{DataTemplate local:AddPage}" />
    <ShellContent Title="Confirmar Adição" ContentTemplate="{DataTemplate local:ConfirmAddPage}" />
    <ShellContent Title="Confirmar Remoção" ContentTemplate="{DataTemplate local:ConfirmRemovePage}" />

</Shell>
