<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Crow.HomePage">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Menu" IconImageSource="menu.png" Clicked="OnMenuButtonClicked"/>
    </ContentPage.ToolbarItems>

    <Grid>
        <Expander x:Name="SidebarExpander">
            <Expander.Header>
                <Label Text="Menu" />
            </Expander.Header>
            <Expander.Content>
                <StackLayout>
                    <Button Text="Entrada" Clicked="OnEntradaClicked" />
                    <Button Text="Saída" Clicked="OnSaidaClicked" />
                    <Button Text="Contas a Ver" Clicked="OnContasAVerClicked" />
                    <Button Text="Contas a Receber" Clicked="OnContasAReceberClicked" />
                </StackLayout>
            </Expander.Content>
        </Expander>

        <StackLayout VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">
            <Label Text="Clique em ☰ para ver mais opções" FontSize="Large" VerticalOptions="Center" HorizontalOptions="Center"/>
        </StackLayout>
    </Grid>
</ContentPage>
